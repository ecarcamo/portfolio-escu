
---
import Layout from '../layouts/Layout.astro';
import Education from '../components/Education.astro';
import AboutMe from '../components/AboutMe.astro';
import ContactMe from '../components/ContactMe.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
---

<Layout>
  <div class="w-screen h-screen p-3">
    <!-- Grid: 1 columna en móvil, 7 columnas y 6 filas en md+ -->
    <div class="grid w-full h-full gap-4 grid-cols-1 lg:grid-cols-7 lg:grid-rows-6">
      
      <!-- #1: Educación -->
      <section class="order-2 lg:order-1 lg:col-span-5 lg:row-span-2 rounded-xl ">
        <Projects />
      </section>

      <!-- #2: AboutMe -->
      <section class="order-1 lg:order-2 lg:col-span-3 lg:row-span-2 lg:col-start-3 lg:row-start-3 ">
        <AboutMe />
      </section>

      <!-- #3: Sección 3 -->
      <section class="order-5 lg:order-3 lg:col-span-2 lg:row-span-4 lg:col-start-6 lg:row-start-1 "> 
        <ContactMe />
      </section>

      <!-- #4: Sección 4 -->
      <section class="order-4 lg:order-4 lg:col-span-5 lg:row-span-2 lg:col-start-3 lg:row-start-5 ">
        <Skills />
      </section>

      <!-- #5: Sección 5 -->
      <section class="order-3 lg:order-5 lg:col-span-2 lg:row-span-4 lg:col-start-1 lg:row-start-3  ">
        <Education />
      </section>

    </div>
  </div>
</Layout>

