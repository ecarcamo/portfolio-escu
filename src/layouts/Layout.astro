---
import "../styles/global.css";
const { title="Portafolio web de Esteban Cárcamo" } = Astro.props;

---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
	</head>
	<body class="m-0 p-0 bg-primary text-white font-poppins">
		<slot />
	</body>
</html>

