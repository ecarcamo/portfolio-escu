
---
const { nameProject, imageDemo, urlDemo, urlRepo } = Astro.props;
---

<div class="relative group w-60 h-35 overflow-hidden rounded-lg shadow-lg">
  <!-- Imagen principal, se opaca al hacer hover -->
  <img 
    src={imageDemo} 
    alt={nameProject + " logo"} 
    class="w-full h-full object-cover transition duration-200 group-hover:opacity-40" 
  />
  
  <!-- Overlay oculto que se muestra al hacer hover -->
  <div class="absolute inset-0 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition duration-200">
    <span class="text-white font-bold text-sm mb-2">{nameProject}</span>
    <a 
      href={urlDemo !== "none" ? urlDemo : urlRepo}
      target="_blank"
      class="px-4 py-2 bg-cian text-white rounded hover:bg-cian-hover transition"
    >
      Ver más
    </a>
  </div>
</div>

