
---
import { skills } from '../data/skills.js';
import SkillItem from '../components/SkillItem.astro';
---


<div class="w-full h-full p-4 bg-secondary rounded-xl overflow-y-auto">

  <h2 class="text-2xl font-bold mb-4 text-center">Habilidades</h2>
  {skills.map(skill => (
    <SkillItem
      name={skill.name}
      bgColor={skill.bgColor}
      textColor={skill.textColor}
      icon={skill.icon}
    />
  ))}
   
</div>
